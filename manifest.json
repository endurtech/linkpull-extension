{
   "action": {
      "default_icon": {
         "16": "icons/LP_icon_16x16.png",
         "192": "icons/LP_icon_192x192.png",
         "32": "icons/LP_icon_32x32.png",
         "512": "icons/LP_icon_512x512.png"
      },
      "default_popup": "popup.html"
   },
   "author": "endurtech",
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "css": [ "content.css" ],
      "js": [ "content.js" ],
      "matches": [ "<all_urls>" ]
   } ],
   "description": "Grab any file straight from a URL. Highlight a link, right-click, or paste it in — LinkPull validates it and pulls it down.",
   "icons": {
      "16": "icons/LP_icon_16x16.png",
      "192": "icons/LP_icon_192x192.png",
      "32": "icons/LP_icon_32x32.png",
      "512": "icons/LP_icon_512x512.png"
   },
   "manifest_version": 3,
   "name": "LinkPull",
   "permissions": [ "downloads", "storage", "activeTab", "contextMenus", "alarms", "notifications" ],
   "version": "1.0.0",
   "web_accessible_resources": [ {
      "matches": [ "<all_urls>" ],
      "resources": [ "icons/*" ]
   } ]
}
